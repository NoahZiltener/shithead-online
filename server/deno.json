{
  "imports": {
    "hono": "jsr:@hono/hono@^4.12.5",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "start": "deno run --allow-net main.ts",
    "dev": "deno run --allow-net --watch main.ts",
    "test": "deno test --allow-net tests/"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
