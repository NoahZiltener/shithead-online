{
  "imports": {
    "@logtape/logtape": "jsr:@logtape/logtape@^2.0.4",
    "hono": "jsr:@hono/hono@^4.12.5",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-env main.ts",
    "dev": "deno run --allow-net --allow-env --env=../.env --watch main.ts",
    "test": "deno test --allow-net --allow-env tests/"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
