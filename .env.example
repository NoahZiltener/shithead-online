# ─────────────────────────────────────────────────────────────────────────────
# Shithead Online — Environment Configuration
#
# Setup:
#   cp .env.example .env
#   Fill in the values below, then start the server.
#
# The .env file is NOT tracked by git. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ───────────────────────────────────────────────────────────────────

# Port the server listens on.
PORT=8000


# ── Discord Webhooks ─────────────────────────────────────────────────────────
# Create webhooks under Server Settings → Integrations → Webhooks in Discord.
# Leave a value empty to disable that webhook.

# Receives feedback submitted by players via the in-game feedback button.
DISCORD_FEEDBACK_WEBHOOK_URL=

# Receives a summary at the end of every game (ranking, mode, duration).
DISCORD_GAME_WEBHOOK_URL=

# Receives application warnings and errors (logged via logtape).
DISCORD_ALERTS_WEBHOOK_URL=
